	private function send_email_now() {
		$stats   = $this->get_stats();
		$subject = $stats['website_name'] . ' - Daily Report';
		$body    = $this->get_email_html($stats);
		$headers = ['Content-Type: text/html; charset=UTF-8'];

		return wp_mail(self::RECIPIENT, $subject, $body, $headers);
	}

	public function send_hourly_email() {
		$this->send_email_now();
	}

	public function preview_email() {
		if (!current_user_can('manage_options')) {
			wp_die('Unauthorized');
		}

		check_admin_referer('skb_dse_preview');

		echo $this->get_email_html($this->get_stats());
		exit;
	}

	public function send_test_email() {
		if (!current_user_can('manage_options')) {
			wp_die('Unauthorized');
		}

		check_admin_referer('skb_dse_send_test');

		$this->send_email_now();

		wp_safe_redirect(admin_url('tools.php?page=skb-daily-stats-email&sent=1'));
		exit;
	}

