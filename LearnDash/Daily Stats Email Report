 

class SKB_Daily_Stats_Email {

	const RECIPIENT = 'mail@pascalheimlicher.com';
	const TIMEZONE  = 'Europe/Stockholm';
	const CRON_HOOK = 'skb_daily_stats_email_hourly';

	public function __construct() {
		add_action('init', [$this, 'schedule_cron']);
		add_action(self::CRON_HOOK, [$this, 'send_hourly_email']);

		add_action('admin_menu', [$this, 'admin_menu']);
		add_action('admin_post_skb_dse_preview', [$this, 'preview_email']);
		add_action('admin_post_skb_dse_send_test', [$this, 'send_test_email']);
	}

	public function schedule_cron() {
		if (!wp_next_scheduled(self::CRON_HOOK)) {
			wp_schedule_event(time() + 60, 'hourly', self::CRON_HOOK);
		}
	}

	public function admin_menu() {
		add_management_page(
			'Daily Stats Email',
			'Daily Stats Email',
			'manage_options',
			'skb-daily-stats-email',
			[$this, 'admin_page']
		);
	}

	private function get_stockholm_window() {
		$tz = new DateTimeZone(self::TIMEZONE);

		$start = new DateTime('today', $tz);
		$end   = new DateTime('tomorrow', $tz);

		$start->setTimezone(new DateTimeZone('UTC'));
		$end->setTimezone(new DateTimeZone('UTC'));

		return [
			'start_utc' => $start->format('Y-m-d H:i:s'),
			'end_utc'   => $end->format('Y-m-d H:i:s'),
		];
	}

	private function get_website_name() {
		return wp_specialchars_decode(get_bloginfo('name'), ENT_QUOTES);
	}

	private function get_user_label($user_id) {
		$user = get_user_by('id', $user_id);

		if (!$user) {
			return '';
		}

		$name  = trim((string) $user->display_name);
		$email = trim((string) $user->user_email);

		if ($name && $email) {
			return $name . ' (' . $email . ')';
		}

		if ($name) {
			return $name;
		}

		if ($email) {
			return $email;
		}

		return 'User #' . absint($user_id);
	}

	private function parse_course_user_ids($course_id) {
		$raw = get_post_meta($course_id, 'wrld_course_users', true);

		if (is_string($raw)) {
			$raw = maybe_unserialize($raw);
		}

		if (is_string($raw)) {
			$raw = maybe_unserialize($raw);
		}

		if (!is_array($raw)) {
			return [];
		}

		return array_values(array_unique(array_filter(array_map('absint', $raw))));
	}

	private function get_students_debug_data() {
		$course_ids = get_posts([
			'post_type'      => 'sfwd-courses',
			'post_status'    => ['publish', 'private', 'draft'],
			'posts_per_page' => -1,
			'fields'         => 'ids',
			'orderby'        => 'ID',
			'order'          => 'ASC',
		]);

		$students      = [];
		$missing_users = [];

		if (empty($course_ids)) {
			return [
				'total'         => 0,
				'students'      => [],
				'missing_users' => [],
			];
		}

		foreach ($course_ids as $course_id) {
			$course_id   = absint($course_id);
			$course_name = get_the_title($course_id);
			$user_ids    = $this->parse_course_user_ids($course_id);

			if (empty($user_ids)) {
				continue;
			}

			foreach ($user_ids as $user_id) {
				$user = get_user_by('id', $user_id);

				if (!$user) {
					if (!isset($missing_users[$user_id])) {
						$missing_users[$user_id] = [
							'user_id' => $user_id,
							'courses' => [],
						];
					}

					$missing_users[$user_id]['courses'][$course_id] = [
						'course_id'   => $course_id,
						'course_name' => $course_name,
					];

					continue;
				}

				if (!isset($students[$user_id])) {
					$students[$user_id] = [
						'user_id'   => $user_id,
						'user_name' => $this->get_user_label($user_id),
						'courses'   => [],
					];
				}

				$students[$user_id]['courses'][$course_id] = [
					'course_id'   => $course_id,
					'course_name' => $course_name,
				];
			}
		}

		return [
			'total'         => count($students),
			'students'      => array_values($students),
			'missing_users' => array_values($missing_users),
		];
	}

	private function get_woocommerce_orders_today_count() {
		if (!function_exists('wc_get_orders')) {
			return 0;
		}

		$window = $this->get_stockholm_window();

		$orders = wc_get_orders([
			'limit'        => -1,
			'status'       => ['processing', 'completed'],
			'date_created' => $window['start_utc'] . '...' . $window['end_utc'],
			'return'       => 'ids',
		]);

		return is_array($orders) ? count($orders) : 0;
	}

	private function get_learndash_transactions_today_count() {
		global $wpdb;

		$window = $this->get_stockholm_window();

		$rows = $wpdb->get_col(
			$wpdb->prepare(
				"
				SELECT ID
				FROM {$wpdb->posts}
				WHERE post_type = %s
				AND post_status = %s
				AND post_date_gmt >= %s
				AND post_date_gmt < %s
				",
				'sfwd-transactions',
				'publish',
				$window['start_utc'],
				$window['end_utc']
			)
		);

		if (empty($rows)) {
			return 0;
		}

		$count = 0;

		foreach ($rows as $transaction_id) {
			$transaction_id = absint($transaction_id);

			$course_id = absint(get_post_meta($transaction_id, 'course_id', true));

			if (!$course_id) {
				$course_id = absint(get_post_meta($transaction_id, 'post_id', true));
			}

			if ($course_id) {
				$count++;
			}
		}

		return $count;
	}

	private function get_stats() {
		$students_debug = $this->get_students_debug_data();

		return [
			'website_name'      => $this->get_website_name(),
			'students_total'    => (int) $students_debug['total'],
			'shop_today'        => $this->get_woocommerce_orders_today_count(),
			'memberships_today' => $this->get_learndash_transactions_today_count(),
			'students_debug'    => $students_debug,
		];
	}

